{
  "name": "pdfpro",
  "version": "1.0.0",
  "description": "Advanced PDF Editor — Node.js 22",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch src/server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:coverage && npm run test:e2e"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.0.0",
    "express-rate-limit": "^8.5.2",
    "multer": "^2.0.0",
    "pdf-lib": "^1.17.0",
    "sharp": "^0.33.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "concurrently": "^9.0.0",
    "jsdom": "^25.0.0",
    "lucide": "^0.400.0",
    "pdfjs-dist": "^4.0.0",
    "sortablejs": "^1.15.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
